# Endpoints DATEX II públicos. São configuráveis porque podem mudar.
MOBIE_STATIC_URL=https://pgm.mobie.pt/integration/nap/evChargingInfra
MOBIE_DYNAMIC_URL=https://pgm.mobie.pt/integration/nap/evActualStatus

# SQLite para teste local. Em produção use a URL PostgreSQL do docker-compose.
DATABASE_URL=sqlite:///./data/mobie_uptime.db
# DATABASE_URL=postgresql+psycopg://mobie:mobie@db:5432/mobie

TIMEZONE=Europe/Lisbon
POLL_SECONDS=60
STATIC_REFRESH_HOUR=2
HTTP_TIMEOUT_SECONDS=180
HTTP_MAX_RETRIES=3
DYNAMIC_FEED_MODE=snapshot
MISSING_FEEDS_BEFORE_UNKNOWN=3
FEED_STALE_AFTER_SECONDS=300
SAVE_RAW_STATIC=true
SAVE_RAW_DYNAMIC=false
RAW_DIRECTORY=./data/raw
USER_AGENT=mobie-uptime/0.1

# Lista opcional de UIDs EVSE, separados por vírgulas.
# Exemplo: EVSE_FILTER=PT*MOB*E0001,PT*MOB*E0002
EVSE_FILTER=
